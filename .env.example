NODE_ENV=development

POSTGRES_DB=novelark
POSTGRES_USER=novelark
POSTGRES_PASSWORD=novelark_password
POSTGRES_PORT=5432

DATABASE_URL=postgresql://novelark:novelark_password@localhost:5432/novelark?schema=public
REDIS_URL=redis://localhost:6379

API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
WEB_PORT=3000
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
INTERNAL_API_URL=http://localhost:4000

# Seeded admin account. Change these before production deployment.
ADMIN_EMAIL=admin@novelark.local
ADMIN_PASSWORD=ChangeMe123!
RESET_ADMIN_PASSWORD=false
ADMIN_SESSION_DAYS=7
# Set true only when the site is served over HTTPS.
ADMIN_COOKIE_SECURE=false
READER_SESSION_DAYS=30
READER_COOKIE_SECURE=false

LOCAL_ASSET_BASE_PATH=storage/covers
PUBLIC_COVER_BASE_URL=/covers

SOURCE_BASE_URL=https://goodluckark.com
CRAWLER_CONCURRENCY=4
CRAWLER_DELAY_MS=250
CRAWLER_TIMEOUT_MS=30000
CRAWLER_RETRIES=3
