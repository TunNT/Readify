{
  "name": "wearenovelark-clone",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "set -a && . ./.env && set +a && pnpm --parallel --filter @wearenovelark/api --filter @wearenovelark/web dev",
    "dev:api": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/api dev",
    "dev:web": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database prisma:generate",
    "db:migrate": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database prisma:migrate",
    "db:deploy": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database prisma:deploy",
    "db:seed": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database db:seed",
    "db:seed:source": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database db:seed:source",
    "db:seed:source:full": "set -a && . ./.env && set +a && pnpm --filter @wearenovelark/database db:seed:source:full",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
