{
  "name": "@wearenovelark/database",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "src/index.ts",
  "scripts": {
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:source": "tsx prisma/import-source.ts --mode=catalog",
    "db:seed:source:full": "tsx prisma/import-source.ts --mode=full"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cheerio": "^1.0.0",
    "p-limit": "^6.2.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
